{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/main/nicegui/elements/lib/tauri/schema/capability.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-spawn",
    "shell:allow-kill",
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:default",
    "fs:allow-read",
    "fs:allow-write",
    "fs:default"
  ]
}
